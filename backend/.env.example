# Server
PORT=3000
NODE_ENV=development  # development | production | test

# Auth
JWT_SECRET=change-me-min-16-chars  # Min 16 caratteri. Obbligatorio solo in produzione (default in sviluppo)
JWT_EXPIRES_IN=7d                   # Token expiry (e.g. 7d, 24h, 3600s)

# Redis (used for rate limiting)
REDIS_URL=redis://localhost:6379
